{
  "_remory_template_version": 1,
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "remory _hook session-end",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "remory _hook pretool",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
