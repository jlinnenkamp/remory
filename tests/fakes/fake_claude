#!/usr/bin/env python3
"""Fake `claude` CLI for integration tests.

This script is the SUBPROCESS-only fake. It is placed first on PATH for
integration tests and accepts the same flags as the real ``claude`` CLI.
Behaviour is steered by environment variables -- see the implementer plan
for the matrix of ``$FAKE_CLAUDE_MODE`` values.

Per the layering rule (tests/fakes/__init__.py), this script imports only
``encode_cwd_for_claude`` from the ``remory`` package. No other imports
from the package; subprocess fidelity must traverse a real fork/exec
boundary.
"""

from __future__ import annotations

import json
import os
import shutil
import sys
import time
from pathlib import Path

from remory.transcripts import encode_cwd_for_claude

_CANNED_ENVELOPE = {
    "type": "result",
    "subtype": "success",
    "is_error": False,
    "result": "ok",
    "session_id": "fake-session-0001",
    "duration_ms": 42,
    "num_turns": 1,
    "stop_reason": "end_turn",
}


def _dump_argv_if_requested(argv: list[str]) -> None:
    dump_path = os.environ.get("FAKE_CLAUDE_ARGV_DUMP")
    if not dump_path:
        return
    Path(dump_path).write_text(
        "\n".join(argv) + ("\n" if argv else ""),
        encoding="utf-8",
    )


def _emit_version_and_exit() -> int:
    sys.stdout.write("fake-claude 0.0.1\n")
    return 0


def _run_scripted() -> int:
    """Per-call scripted response mode.

    ``FAKE_CLAUDE_SCRIPT_FILE`` -- JSON file containing a list of strings;
    each string is the ``result`` value the fake will return for that
    invocation (wrapped in an envelope). Counter persists across re-execs
    via ``FAKE_CLAUDE_SCRIPT_COUNTER_FILE``.

    Used by the Phase 3 sleep integration tests where one sleep run produces
    multiple distinct headless calls (extract, merges, critique).
    """
    script_path = os.environ.get("FAKE_CLAUDE_SCRIPT_FILE")
    counter_path = os.environ.get("FAKE_CLAUDE_SCRIPT_COUNTER_FILE")
    if not script_path or not counter_path:
        sys.stderr.write(
            "fake_claude: scripted mode requires FAKE_CLAUDE_SCRIPT_FILE and "
            "FAKE_CLAUDE_SCRIPT_COUNTER_FILE\n"
        )
        return 2
    try:
        responses_raw = json.loads(Path(script_path).read_text(encoding="utf-8"))
    except (FileNotFoundError, json.JSONDecodeError) as exc:
        sys.stderr.write(f"fake_claude: cannot read script file {script_path}: {exc}\n")
        return 2
    if not isinstance(responses_raw, list):
        sys.stderr.write("fake_claude: script file must contain a JSON list\n")
        return 2

    cf = Path(counter_path)
    try:
        counter = int(cf.read_text(encoding="utf-8")) if cf.exists() else 0
    except (OSError, ValueError):
        counter = 0
    if counter >= len(responses_raw):
        sys.stderr.write(
            f"fake_claude: script exhausted (counter={counter}, len={len(responses_raw)})\n"
        )
        return 2
    text = str(responses_raw[counter])
    cf.write_text(str(counter + 1), encoding="utf-8")

    env = dict(_CANNED_ENVELOPE)
    env["result"] = text
    sys.stdout.write(json.dumps(env) + "\n")
    return 0


def _run_headless() -> int:
    mode = os.environ.get("FAKE_CLAUDE_MODE", "success")

    if mode == "success":
        sys.stdout.write(json.dumps(_CANNED_ENVELOPE) + "\n")
        return 0
    if mode == "success_text":
        env = dict(_CANNED_ENVELOPE)
        env["result"] = os.environ.get("FAKE_CLAUDE_TEXT", "ok")
        sys.stdout.write(json.dumps(env) + "\n")
        return 0
    if mode == "scripted":
        return _run_scripted()
    if mode == "malformed_json":
        sys.stdout.write("not json {\n")
        return 0
    if mode == "nonzero_exit":
        sys.stdout.write(json.dumps(_CANNED_ENVELOPE) + "\n")
        return int(os.environ.get("FAKE_CLAUDE_EXIT_CODE", "1"))
    if mode == "hang":
        time.sleep(int(os.environ.get("FAKE_CLAUDE_HANG_SECONDS", "9999")))
        return 0
    if mode == "is_error_envelope":
        env = dict(_CANNED_ENVELOPE)
        env["is_error"] = True
        env["result"] = os.environ.get("FAKE_CLAUDE_TEXT", "auth failed")
        sys.stdout.write(json.dumps(env) + "\n")
        return 0

    sys.stderr.write(f"fake_claude: unknown FAKE_CLAUDE_MODE={mode!r}\n")
    return 2


_WIZARD_DEFAULT_LETTER = (
    "Hi there. You picked your topics and shared what you're hoping for. "
    "I'll keep what you bring me here, and only what you bring me.\n"
)


def _run_wizard_interactive() -> int:
    """Phase 6 wizard-subagent mode: write answers.json + letter.md.

    Env contract (plan §12):
      FAKE_CLAUDE_WIZARD_RUN_DIR  — absolute path; required.
      FAKE_CLAUDE_WIZARD_ANSWERS  — JSON string written to answers.json.
      FAKE_CLAUDE_WIZARD_LETTER   — string written to letter.md.
      FAKE_CLAUDE_WIZARD_FAIL     — one of: preflight_exit_nonzero,
                                    write_malformed_json_once,
                                    write_malformed_json_twice,
                                    missing_answers_file.

    Invocation counter (for write_malformed_json_once) lives at
    ``<FAKE_CLAUDE_WIZARD_RUN_DIR>/.fake_claude_invocations``.
    """
    run_dir_str = os.environ.get("FAKE_CLAUDE_WIZARD_RUN_DIR")
    if not run_dir_str:
        sys.stderr.write(
            "fake_claude: wizard_interactive mode requires FAKE_CLAUDE_WIZARD_RUN_DIR\n"
        )
        return 2
    run_dir = Path(run_dir_str)
    run_dir.mkdir(parents=True, exist_ok=True)

    fail_mode = os.environ.get("FAKE_CLAUDE_WIZARD_FAIL", "")

    if fail_mode == "preflight_exit_nonzero":
        return 1

    # Determine invocation index (0-based).
    counter_path = run_dir / ".fake_claude_invocations"
    try:
        invocation = int(counter_path.read_text(encoding="utf-8"))
    except (OSError, ValueError):
        invocation = 0
    counter_path.write_text(str(invocation + 1), encoding="utf-8")

    answers_target = run_dir / "answers.json"
    letter_target = run_dir / "letter.md"

    letter_body = os.environ.get("FAKE_CLAUDE_WIZARD_LETTER", _WIZARD_DEFAULT_LETTER)

    if fail_mode == "missing_answers_file":
        letter_target.write_text(letter_body, encoding="utf-8")
        return 0

    if fail_mode == "write_malformed_json_twice":
        answers_target.write_text("{not json", encoding="utf-8")
        letter_target.write_text(letter_body, encoding="utf-8")
        return 0

    if fail_mode == "write_malformed_json_once" and invocation == 0:
        answers_target.write_text("{not json", encoding="utf-8")
        letter_target.write_text(letter_body, encoding="utf-8")
        return 0

    # Default / second-invocation success path.
    answers_raw = os.environ.get("FAKE_CLAUDE_WIZARD_ANSWERS")
    if not answers_raw:
        sys.stderr.write(
            "fake_claude: wizard_interactive mode requires FAKE_CLAUDE_WIZARD_ANSWERS\n"
        )
        return 2
    answers_target.write_text(answers_raw, encoding="utf-8")
    letter_target.write_text(letter_body, encoding="utf-8")
    return 0


def _run_interactive(argv: list[str]) -> int:
    mode = os.environ.get("FAKE_CLAUDE_MODE", "")
    if mode == "wizard_interactive":
        return _run_wizard_interactive()
    if os.environ.get("FAKE_CLAUDE_INTERACTIVE_FAIL") == "1":
        return 1
    if os.environ.get("FAKE_CLAUDE_EXPECT_RESUME") == "1" and "--resume" not in argv:
        sys.stderr.write("fake_claude: expected --resume but it was not provided\n")
        return 2

    session_id = os.environ.get("FAKE_CLAUDE_SESSION_ID", "fake-session-0001")
    home_root = os.environ.get("FAKE_CLAUDE_HOME") or str(Path.home() / ".claude")
    encoded = encode_cwd_for_claude(Path.cwd())
    project_dir = Path(home_root) / "projects" / encoded
    project_dir.mkdir(parents=True, exist_ok=True)
    dest = project_dir / f"{session_id}.jsonl"

    src = os.environ.get("FAKE_CLAUDE_TRANSCRIPT_FILE")
    if src:
        src_path = Path(src)
        if not src_path.exists() or src_path.stat().st_size == 0:
            sys.stderr.write(f"fake_claude: transcript file {src} missing or empty\n")
            return 1
        shutil.copyfile(src_path, dest)
        return 0

    user_event = {
        "type": "user",
        "message": {
            "role": "user",
            "content": [{"type": "text", "text": "hello"}],
        },
        "uuid": "00000000-0000-0000-0000-000000000001",
        "timestamp": "2026-05-09T09:30:00.000Z",
        "sessionId": session_id,
        "isSidechain": False,
    }
    assistant_event = {
        "type": "assistant",
        "message": {
            "role": "assistant",
            "content": [{"type": "text", "text": "hi there"}],
        },
        "uuid": "00000000-0000-0000-0000-000000000002",
        "timestamp": "2026-05-09T09:30:01.000Z",
        "sessionId": session_id,
        "isSidechain": False,
    }
    dest.write_text(
        json.dumps(user_event) + "\n" + json.dumps(assistant_event) + "\n",
        encoding="utf-8",
    )
    return 0


def main(argv: list[str]) -> int:
    _dump_argv_if_requested(argv)

    if "--version" in argv:
        return _emit_version_and_exit()

    if "-p" in argv:
        return _run_headless()

    return _run_interactive(argv)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
